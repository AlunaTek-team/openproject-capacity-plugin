}

/* ── Variables: tema oscuro ── */
/* 1) Clase "dark" en <html> — toggle manual de OpenProject */
html.dark #cm-dashboard {
  --cm-bg-page:       transparent;
  --cm-bg-card:       #22272e;
  --cm-bg-hover:      #2d333b;
  --cm-bg-row-hover:  #2d333b;
  --cm-bg-total:      #2a2f37;
  --cm-bg-danger:     #3d1f1f;
  --cm-bg-input:      #1c2128;

  --cm-text-primary:   #adbac7;
  --cm-text-secondary: #768390;
  --cm-text-tertiary:  #545d68;

  --cm-border:       #444c56;
  --cm-border-light: #373e47;
  --cm-border-row:   #2d333b;

  --cm-color-primary:       #539bf5;
  --cm-color-primary-hover: #6cb6ff;
  --cm-color-primary-focus: rgba(83,155,245,0.20);
  --cm-color-success:       #57ab5a;
  --cm-color-danger:        #e5534b;
  --cm-color-warning:       #c69026;
  --cm-color-btn-disabled:  #444c56;

  --cm-badge-blue-bg:    #1b3a5c;
  --cm-badge-blue-text:  #6cb6ff;
  --cm-badge-green-bg:   #1a3520;
  --cm-badge-green-text: #57ab5a;
  --cm-badge-orange-bg:  #3a2a0a;
  --cm-badge-orange-text:#c69026;

  --cm-shadow: 0 1px 3px rgba(0,0,0,0.30);
  --cm-shadow-panel: 0 4px 16px rgba(0,0,0,0.40);
}

/* 2) Preferencia del sistema operativo */
@media (prefers-color-scheme: dark) {
  #cm-dashboard {
    --cm-bg-page:       transparent;
    --cm-bg-card:       #22272e;
    --cm-bg-hover:      #2d333b;
    --cm-bg-row-hover:  #2d333b;
    --cm-bg-total:      #2a2f37;
    --cm-bg-danger:     #3d1f1f;
    --cm-bg-input:      #1c2128;

    --cm-text-primary:   #adbac7;
    --cm-text-secondary: #768390;
    --cm-text-tertiary:  #545d68;

    --cm-border:       #444c56;
    --cm-border-light: #373e47;
    --cm-border-row:   #2d333b;

    --cm-color-primary:       #539bf5;
    --cm-color-primary-hover: #6cb6ff;
    --cm-color-primary-focus: rgba(83,155,245,0.20);
    --cm-color-success:       #57ab5a;
    --cm-color-danger:        #e5534b;
    --cm-color-warning:       #c69026;
    --cm-color-btn-disabled:  #444c56;

    --cm-badge-blue-bg:    #1b3a5c;
    --cm-badge-blue-text:  #6cb6ff;
    --cm-badge-green-bg:   #1a3520;
    --cm-badge-green-text: #57ab5a;
    --cm-badge-orange-bg:  #3a2a0a;
    --cm-badge-orange-text:#c69026;

    --cm-shadow: 0 1px 3px rgba(0,0,0,0.30);
    --cm-shadow-panel: 0 4px 16px rgba(0,0,0,0.40);
  }
}

