/* ── Columna de progreso ── */
.cm-td-bar { min-width: 300px; }

/* Wrapper: barra a la izquierda, badge a la derecha */
.cm-progress-wrap {
  display: flex;
  align-items: center;
  gap: 10px;
}

/* Columna interna: barra + meta-texto */
.cm-progress-inner {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 4px;
}

/* Pista de la barra — fondo gris = capacidad libre */
.cm-progress-track {
  position: relative;
