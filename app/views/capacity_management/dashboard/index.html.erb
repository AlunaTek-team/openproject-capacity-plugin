<div id="cm-dashboard"
     data-sprint-id="<%= @sprint&.id %>"
     data-save-path="<%= capacity_management_save_capacity_path rescue '' %>">

  <%# ── CABECERA: filtros de proyecto + selector de sprint + info sprint ── %>
  <div class="cm-page-header">
    <div class="cm-title-row">
      <h2 class="cm-title">Capacidad y Carga del Sprint</h2>
    </div>

    <div class="cm-filters-row">
      <form method="get" id="cm-filters-form" class="cm-filters-form">

        <%# ── Filtro de proyectos: dropdown con checkboxes ── %>
        <%
          # Calcular qué proyectos están seleccionados actualmente
          active_ids = if @project_filter_mode == 'selected' && @selected_project_ids.any?
                         @selected_project_ids
                       elsif @project_filter_mode == 'all'
                         @available_projects.map { |p| p[:id] }
                       elsif @project_filter_mode == 'children'
                         @available_projects.select { |p| p[:parent_id].present? }.map { |p| p[:id] }
                       else
                         [@project.id]
                       end
          all_selected = active_ids.sort == @available_projects.map { |p| p[:id] }.sort

          # Texto del botón
          if all_selected && @available_projects.size > 1
            btn_text = "Todos los proyectos (#{@available_projects.size})"
          elsif active_ids.size == 1
            btn_text = @available_projects.find { |p| p[:id] == active_ids.first }&.dig(:name) || 'Proyecto actual'
          else
            btn_text = "#{active_ids.size} proyectos seleccionados"
          end
        %>
        <%
          children_ids = @available_projects.select { |p| p[:parent_id].present? }.map { |p| p[:id] }
          all_children_checked = children_ids.any? && children_ids.all? { |id| active_ids.include?(id) }
        %>
        <div class="cm-filter-group">
          <label class="cm-filter-label">Proyectos</label>
          <input type="hidden" name="project_filter" value="selected" />
          <div class="cm-multiselect" id="cm-project-dropdown">
            <button type="button" class="cm-multiselect-btn" id="cm-multiselect-trigger">
              <span id="cm-multiselect-label"><%= btn_text %></span>
              <svg class="cm-multiselect-arrow" viewBox="0 0 20 20" fill="currentColor" width="14" height="14">
                <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 11.17l3.71-3.94a.75.75 0 111.1 1.02l-4.25 4.5a.75.75 0 01-1.1 0L5.21 8.27a.75.75 0 01.02-1.06z"/>
              </svg>
            </button>
          </div>

          <%# Panel fuera del div.cm-multiselect para evitar clipping por overflow:hidden %>
          <div class="cm-multiselect-panel" id="cm-multiselect-panel" style="display:none">
            <%# Tabs %>
            <div class="cm-ms-tabs">
              <button type="button" class="cm-ms-tab cm-ms-tab-active" id="cm-tab-all">Todos los proyectos</button>
              <button type="button" class="cm-ms-tab" id="cm-tab-selected">Solo seleccionados</button>
            </div>
            <%# Búsqueda %>
            <div class="cm-ms-search-wrap">
              <svg class="cm-ms-search-icon" viewBox="0 0 16 16" fill="currentColor" width="14" height="14">
                <path d="M10.68 11.74a6 6 0 0 1-7.922-8.982 6 6 0 0 1 8.982 7.922l3.04 3.04a.75.75 0 1 1-1.06 1.06l-3.04-3.04ZM11.5 7a4.5 4.5 0 1 1-9 0 4.5 4.5 0 0 1 9 0Z"/>
              </svg>
              <input type="text" class="cm-ms-search" id="cm-ms-search" placeholder="Buscar proyectos..." />
            </div>
            <%# Lista de proyectos %>
            <div class="cm-multiselect-list" id="cm-ms-list">
              <% @available_projects.each do |p| %>
                <%
                  is_parent = p[:parent_id].nil?
                  is_checked = active_ids.include?(p[:id])
                  proj_dash_url = "/projects/#{p[:identifier]}/capacity_management/"
                %>
                <div class="cm-multiselect-item-row" data-name="<%= h(p[:name].downcase) %>">
                  <label class="cm-multiselect-item <%= 'cm-multiselect-item-child' unless is_parent %>">
                    <input type="checkbox" name="project_ids[]" value="<%= p[:id] %>"
                           data-is-child="<%= is_parent ? 'false' : 'true' %>"
                           <%= 'checked' if is_checked %> />
                    <% if is_parent %>
                      <span class="cm-project-icon cm-project-icon-parent">&#9632;</span>
                    <% else %>
                      <span class="cm-project-icon cm-project-icon-child">&#9500;</span>
                    <% end %>
                    <span class="cm-multiselect-item-name"><%= p[:name] %></span>
                  </label>
                  <a href="<%= proj_dash_url %>" class="cm-proj-nav-link" title="Ir al dashboard de <%= h(p[:name]) %>">
                    <svg viewBox="0 0 16 16" fill="currentColor" width="12" height="12">
                      <path d="M3.75 2h3.5a.75.75 0 0 1 0 1.5h-3.5a.25.25 0 0 0-.25.25v8.5c0 .138.112.25.25.25h8.5a.25.25 0 0 0 .25-.25v-3.5a.75.75 0 0 1 1.5 0v3.5A1.75 1.75 0 0 1 12.25 14h-8.5A1.75 1.75 0 0 1 2 12.25v-8.5C2 2.784 2.784 2 3.75 2Zm6.854-1h4.146a.25.25 0 0 1 .25.25v4.146a.25.25 0 0 1-.427.177L13.03 4.03 9.28 7.78a.751.751 0 0 1-1.042-.018.751.751 0 0 1-.018-1.042l3.75-3.75-1.543-1.543A.25.25 0 0 1 10.604 1Z"/>
                    </svg>
                  </a>
                </div>
              <% end %>
            </div>
            <%# Pie %>
            <div class="cm-ms-footer">
              <% if children_ids.any? %>
              <label class="cm-ms-include-sub-label">
                <input type="checkbox" id="cm-include-sub"
                       <%= 'checked' if all_children_checked %> />
                <span>Incluir todos los subproyectos</span>
              </label>
              <% end %>
              <div class="cm-ms-footer-btns">
                <button type="button" class="cm-ms-clear-btn" id="cm-ms-clear-btn">Borrar selecci&oacute;n</button>
                <button type="button" class="cm-multiselect-apply" id="cm-ms-apply-btn">Aplicar</button>
              </div>
            </div>
          </div>
        </div>

        <%# Selector de sprint %>
        <div class="cm-filter-group">
          <label class="cm-filter-label">Sprint</label>
          <select name="sprint_id" class="cm-filter-select" id="cm-sprint-select">
            <option value="">-- Seleccionar --</option>
            <% @sprints.each do |s| %>
              <option value="<%= s.id %>" <%= 'selected' if s.id == @sprint&.id %>>
                <%= s.name %>
                <% if s.start_date && s.effective_date %>
                  (<%= s.start_date.strftime('%d/%m') %> - <%= s.effective_date.strftime('%d/%m') %>)
                <% end %>
              </option>
            <% end %>
          </select>
        </div>

        <%# Hidden inputs para mantener project_ids al cambiar sprint (se manejan via JS) %>
        <div id="cm-hidden-project-ids">
          <% active_ids.each do |pid| %>
            <input type="hidden" name="project_ids[]" value="<%= pid %>" />
          <% end %>
        </div>
      </form>
    </div>
  </div>

  <% if @sprint.nil? %>
    <div class="cm-empty-state">
      <p>No hay sprints (versiones) configurados en los proyectos seleccionados.</p>
      <p>Ve a <strong>Configuraci&oacute;n del proyecto &rarr; Versiones</strong> para crear sprints.</p>
    </div>
  <% else %>

  <%# ── INFORMACI&Oacute;N DEL SPRINT ── %>
  <div class="cm-sprint-info-card">
    <div class="cm-sprint-info-header">
      <h3 class="cm-sprint-info-title"><%= @sprint_info[:name] %></h3>
      <div class="cm-sprint-info-badges">
        <span class="cm-badge cm-badge-blue"><%= @sprint_info[:total_tasks] %> tareas</span>
        <span class="cm-badge cm-badge-green"><%= @sprint_info[:completed_tasks] %> completadas</span>
        <span class="cm-badge cm-badge-orange"><%= @sprint_info[:pending_tasks] %> pendientes</span>
      </div>
    </div>
    <div class="cm-sprint-info-details">
      <div class="cm-sprint-detail">
        <span class="cm-detail-label">Fecha inicio</span>
        <span class="cm-detail-value"><%= @sprint_info[:start_date] %></span>
      </div>
      <div class="cm-sprint-detail">
        <span class="cm-detail-label">Fecha fin</span>
        <span class="cm-detail-value"><%= @sprint_info[:end_date] %></span>
      </div>
      <div class="cm-sprint-detail">
        <span class="cm-detail-label">D&iacute;as h&aacute;biles</span>
        <span class="cm-detail-value"><%= @sprint_info[:total_work_days] %></span>
      </div>
      <div class="cm-sprint-detail">
        <span class="cm-detail-label">Restantes</span>
        <span class="cm-detail-value"><%= @sprint_info[:work_days_remaining] %></span>
      </div>
      <% if @sprint_info[:projects_count] && @sprint_info[:projects_count] > 1 %>
      <div class="cm-sprint-detail cm-sprint-detail-wide">
        <span class="cm-detail-label">Proyectos incluidos</span>
        <span class="cm-detail-value"><%= @sprint_info[:projects_names].join(', ') %></span>
      </div>
      <% end %>
    </div>
  </div>

  <%# ── TARJETAS DE RESUMEN ── %>
  <div class="cm-summary-cards">
    <div class="cm-card">
      <div class="cm-card-label">Capacidad total</div>
      <div class="cm-card-value"><%= @team_summary[:total_capacity] %>h</div>
      <div class="cm-card-sub"><%= @sprint_info[:total_work_days] %> d&iacute;as h&aacute;biles</div>
    </div>
    <% over_capacity = @team_summary[:total_capacity] > 0 && @team_summary[:total_estimated] > @team_summary[:total_capacity] %>
    <div class="cm-card">
      <div class="cm-card-label">Trabajo asignado</div>
      <div class="cm-card-value <%= 'cm-value-over' if over_capacity %>"><%= @team_summary[:total_estimated] %>h</div>
      <% assigned_pct = @team_summary[:total_capacity] > 0 ? (@team_summary[:total_estimated] / @team_summary[:total_capacity] * 100).round(1) : 0 %>
      <div class="cm-card-sub"><%= assigned_pct %>% de la capacidad</div>
    </div>
    <div class="cm-card">
      <div class="cm-card-label">Invertido</div>
      <div class="cm-card-value cm-value-done"><%= @team_summary[:completed_hours] %>h</div>
      <div class="cm-card-sub"><%= @team_summary[:percent_complete] %>% del asignado</div>
    </div>
    <div class="cm-card">
      <div class="cm-card-label">Pendiente</div>
      <div class="cm-card-value"><%= @team_summary[:remaining_hours] %>h</div>
      <div class="cm-card-sub">en tareas abiertas</div>
    </div>
  </div>

  <%# ── BURNDOWN ── %>
  <% stats = @burndown[:stats] %>
  <% if stats && stats[:total_scope] > 0 %>
  <div class="cm-section">
    <div class="cm-section-header">
      <h3>Burndown del Sprint</h3>
      <div class="cm-burndown-legend">
        <span class="cm-leg cm-leg-remaining">&#9644; Trabajo restante</span>
        <span class="cm-leg cm-leg-capacity">&#8212; &#8212; Capacidad restante</span>
        <span class="cm-leg cm-leg-ideal">&#8212; Tendencia ideal</span>
      </div>
    </div>
    <div class="cm-burndown-stats-row">
      <div class="cm-bstat">
        <span class="cm-bstat-val"><%= stats[:percent_complete] %>%</span>
        <span class="cm-bstat-label">Completado</span>
      </div>
      <div class="cm-bstat">
        <span class="cm-bstat-val"><%= stats[:avg_burndown] %>h/d&iacute;a</span>
        <span class="cm-bstat-label">Burndown necesario</span>
      </div>
      <div class="cm-bstat">
        <span class="cm-bstat-val"><%= stats[:not_estimated] %></span>
        <span class="cm-bstat-label">Sin estimaci&oacute;n</span>
      </div>
      <div class="cm-bstat">
        <span class="cm-bstat-val"><%= stats[:total_scope] %>h</span>
        <span class="cm-bstat-label">Alcance total</span>
      </div>
      <div class="cm-bstat">
        <span class="cm-bstat-val"><%= stats[:current_remaining] %>h</span>
        <span class="cm-bstat-label">Horas restantes</span>
      </div>
    </div>
    <div class="cm-chart-wrap">
      <canvas id="cm-burndown-chart" data-burndown="<%= @burndown.to_json %>"></canvas>
    </div>
  </div>
  <% end %>

  <%# ── CONFIGURACI&Oacute;N DE CAPACIDAD POR MIEMBRO ── %>
  <div class="cm-section">
    <div class="cm-section-header">
      <h3>Capacidad por miembro (horas/d&iacute;a)</h3>
      <button type="button" class="cm-btn-save" id="cm-save-capacity-btn" disabled>
        Guardar cambios
      </button>
    </div>
    <p class="cm-capacity-help">
      Configura las horas disponibles por d&iacute;a y los d&iacute;as que cada miembro estar&aacute; disponible en este sprint.
      La capacidad individual se calcula como <strong>horas/d&iacute;a &times; d&iacute;as disponibles</strong>.
    </p>
    <table class="cm-capacity-table">
      <thead>
        <tr>
          <th>Miembro</th>
          <th class="cm-th-c">Horas/d&iacute;a</th>
          <th class="cm-th-c">D&iacute;as disponibles</th>
          <th class="cm-th-c">Capacidad</th>
        </tr>
      </thead>
      <tbody>
        <% @capacity_configs.each do |cfg| %>
          <tr>
            <td class="cm-td-user">
              <span class="cm-avatar"><%= cfg[:initials] %></span>
              <span><%= cfg[:user_name] %></span>
            </td>
            <td class="cm-th-c">
              <input type="number"
                     class="cm-capacity-input cm-input-hours"
                     data-user-id="<%= cfg[:user_id] %>"
                     data-field="hours"
                     value="<%= cfg[:hours_per_day] %>"
                     min="0.5" max="24" step="0.5"
                     />
            </td>
            <td class="cm-th-c">
              <input type="number"
                     class="cm-capacity-input cm-input-days"
                     data-user-id="<%= cfg[:user_id] %>"
                     data-field="days"
                     data-sprint-days="<%= cfg[:sprint_work_days] %>"
                     value="<%= cfg[:available_days] %>"
                     min="1" max="<%= cfg[:sprint_work_days] %>" step="1"
                     title="D&iacute;as h&aacute;biles del sprint: <%= cfg[:sprint_work_days] %>" />
            </td>
            <td class="cm-th-c cm-capacity-preview" data-user-id="<%= cfg[:user_id] %>">
              <%= (cfg[:hours_per_day] * cfg[:available_days]).round(1) %>h
            </td>
          </tr>
        <% end %>
        <% if @capacity_configs.empty? %>
          <tr>
            <td colspan="4" class="cm-empty-state">No hay miembros en los proyectos seleccionados.</td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <%# ── TABLA DE MIEMBROS ── %>
  <div class="cm-section">
    <div class="cm-section-header">
      <h3>Trabajo por miembro</h3>
      <div class="cm-prog-legend-global">
        <span class="cm-legend-swatch cm-swatch-logged"></span><span>Invertido</span>
        <span class="cm-legend-swatch cm-swatch-pending"></span><span>Pendiente</span>
        <span class="cm-legend-marker-pip"></span><span>Esperado hoy</span>
      </div>
    </div>
    <% if @member_rows.empty? %>
      <p class="cm-empty-state">No hay miembros en los proyectos seleccionados.</p>
    <% else %>
    <table class="cm-member-table">
      <thead>
        <tr>
          <th>Miembro</th>
          <th>Progreso en el Sprint</th>
          <th class="cm-th-r">Asignado</th>
          <th class="cm-th-r">Invertido</th>
          <th class="cm-th-r">Pendiente</th>
        </tr>
      </thead>
      <tbody>
        <% @member_rows.each do |m| %>
          <%
            cap = m[:capacity].to_f
            if cap > 0
              logged_pct   = [(m[:logged]         / cap * 100), 100].min.round(2)
              assigned_pct = [(m[:assigned]        / cap * 100), 100].min.round(2)
              expected_pct = [(m[:expected_today]  / cap * 100), 100].min.round(2)
            else
              logged_pct = assigned_pct = expected_pct = 0.0
            end

            case m[:speed_status]
            when :slow
              badge_cls  = 'cm-speed-slow'
              badge_icon = '&#9660;'
              badge_label = 'Lento'
              badge_tip = "Avance real: #{m[:logged]}h\nEsperado hoy: #{m[:expected_today]}h\nRatio: #{m[:speed_ratio]}%\n\nDías transcurridos: #{m[:elapsed_days]} de #{m[:avail_days]} días disponibles\nUmbrales: <80% = lento · 80-110% = normal · >110% = adelantado"
            when :normal
              badge_cls  = 'cm-speed-normal'
              badge_icon = '&#10003;'
              badge_label = 'Normal'
              badge_tip = "Avance real: #{m[:logged]}h\nEsperado hoy: #{m[:expected_today]}h\nRatio: #{m[:speed_ratio]}%\n\nDías transcurridos: #{m[:elapsed_days]} de #{m[:avail_days]} días disponibles\nUmbrales: <80% = lento · 80-110% = normal · >110% = adelantado"
            when :fast
              badge_cls  = 'cm-speed-fast'
              badge_icon = '&#9650;'
              badge_label = 'Adelantado'
              badge_tip = "Avance real: #{m[:logged]}h\nEsperado hoy: #{m[:expected_today]}h\nRatio: #{m[:speed_ratio]}%\n\nDías transcurridos: #{m[:elapsed_days]} de #{m[:avail_days]} días disponibles\nUmbrales: <80% = lento · 80-110% = normal · >110% = adelantado"
            when :no_assign
              badge_cls = 'cm-speed-nodata'
              badge_icon = '&#8212;'
              badge_label = 'Sin tareas'
              badge_tip = 'Sin tareas asignadas en este sprint'
            else
              badge_cls = 'cm-speed-nodata'
              badge_icon = '&#8212;'
              badge_label = 'Sin datos'
              badge_tip = "El sprint aún no ha comenzado\nDías disponibles del miembro: #{m[:avail_days]}"
            end

            bar_tip = "Invertido: #{m[:logged]}h  ·  Pendiente: #{m[:remaining_open]}h  ·  Asignado: #{m[:assigned]}h  ·  Capacidad: #{m[:capacity]}h  ·  Esperado hoy: #{m[:expected_today]}h"
          %>
          <tr<%= m[:overloaded] ? ' class="cm-row-over"' : '' %>>
            <td>
              <div class="cm-td-user">
                <span class="cm-avatar"><%= m[:initials] %></span>
                <a href="<%= m[:wp_url] %>" class="cm-member-link"><%= m[:user_name] %></a>
              </div>
            </td>
            <td class="cm-td-bar">
              <div class="cm-progress-wrap">
                <div class="cm-progress-inner">
                  <div class="cm-progress-track" title="<%= bar_tip %>">
                    <%# Capa 1 (verde semitransparente): trabajo asignado total %>
                    <% if assigned_pct > 0 %>
                    <div class="cm-prog-assigned" style="width:<%= assigned_pct %>%"></div>
                    <% end %>
                    <%# Capa 2 (azul): horas realmente invertidas %>
                    <% if logged_pct > 0 %>
                    <div class="cm-prog-logged" style="width:<%= logged_pct %>%"></div>
                    <% end %>
                    <%# Marcador naranja: avance esperado a la fecha %>
                    <% if expected_pct > 0 %>
                    <div class="cm-prog-marker" style="left:<%= expected_pct %>%"
                         title="Esperado hoy: <%= m[:expected_today] %>h"></div>
                    <% end %>
                  </div>
                  <div class="cm-prog-meta">
                    <%= m[:logged] %>h inv. &nbsp;&middot;&nbsp; <%= m[:assigned] %>h asig. &nbsp;&middot;&nbsp; cap: <%= m[:capacity] %>h
                  </div>
                </div>
                <span class="cm-speed-badge <%= badge_cls %>" title="<%= badge_tip %>">
                  <%= badge_icon.html_safe %>&nbsp;<%= badge_label %>
                </span>
              </div>
            </td>
            <td class="cm-td-r"><%= m[:assigned] %>h</td>
            <td class="cm-td-r cm-td-done"><%= m[:logged] %>h</td>
            <td class="cm-td-r"><%= m[:remaining_open] %>h</td>
          </tr>
        <% end %>
        <%# Fila total %>
        <% t = @team_summary %>
        <% if t[:total_capacity] > 0 %>
          <% t_assigned_pct = [(t[:total_estimated] / t[:total_capacity] * 100), 100].min.round(2) %>
          <% t_logged_pct   = [(t[:completed_hours] / t[:total_capacity] * 100), 100].min.round(2) %>
        <% else %>
          <% t_assigned_pct = 0; t_logged_pct = 0 %>
        <% end %>
        <tr class="cm-row-total">
          <td><strong>Total equipo</strong></td>
          <td class="cm-td-bar">
            <div class="cm-progress-wrap">
              <div class="cm-progress-inner">
                <div class="cm-progress-track">
                  <% if t_assigned_pct > 0 %>
                  <div class="cm-prog-assigned" style="width:<%= t_assigned_pct %>%"></div>
                  <% end %>
                  <% if t_logged_pct > 0 %>
                  <div class="cm-prog-logged" style="width:<%= t_logged_pct %>%"></div>
                  <% end %>
                </div>
                <div class="cm-prog-meta">
                  <%= t[:completed_hours] %>h inv. &nbsp;&middot;&nbsp; <%= t[:total_estimated] %>h asig. &nbsp;&middot;&nbsp; cap: <%= t[:total_capacity] %>h
                </div>
              </div>
            </div>
          </td>
          <td class="cm-td-r"><strong><%= t[:total_estimated] %>h</strong></td>
          <td class="cm-td-r cm-td-done"><strong><%= t[:completed_hours] %>h</strong></td>
          <td class="cm-td-r"><strong><%= t[:remaining_hours] %>h</strong></td>
        </tr>
      </tbody>
    </table>
    <% end %>
  </div>

  <% end -%><%# fin @sprint.nil? %>
</div>

<script src="/assets/capacity_management/chart.min.js"></script>
<script src="/assets/capacity_management/dashboard.js"></script>

<style>
/* ── Variables: tema claro (por defecto) ── */
#cm-dashboard {
  --cm-bg-page:       transparent;
  --cm-bg-card:       #ffffff;
  --cm-bg-hover:      #f3f2f1;
  --cm-bg-row-hover:  #faf9f8;
  --cm-bg-total:      #f8f8f8;
  --cm-bg-danger:     #fdf3f3;
  --cm-bg-input:      #ffffff;

  --cm-text-primary:   #201f1e;
  --cm-text-secondary: #605e5c;
  --cm-text-tertiary:  #a19f9d;

  --cm-border:       #c8c6c4;
  --cm-border-light: #edebe9;
  --cm-border-row:   #f3f2f1;

  --cm-color-primary:       #0078d4;
  --cm-color-primary-hover: #106ebe;
  --cm-color-primary-focus: rgba(0,120,212,0.15);
  --cm-color-success:       #107c10;
  --cm-color-danger:        #a4262c;
  --cm-color-warning:       #ff8c00;
  --cm-color-btn-disabled:  #c8c6c4;

  --cm-badge-blue-bg:    #e8f0fe;
  --cm-badge-blue-text:  #1967d2;
  --cm-badge-green-bg:   #e6f4ea;
  --cm-badge-green-text: #137333;
